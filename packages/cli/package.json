  "version": "0.1.0",
  "description": "Collect local AI-coding token usage via ccusage and sync it to your Cloudflare Worker.",
  "license": "MIT",
  "author": "Danny Chyou",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dannyball710/ccusage-hub.git",
